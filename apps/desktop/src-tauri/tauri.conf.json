{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NyraQ",
  "version": "0.1.1",
  "identifier": "com.sthyra.quantos",
  "build": {
    "beforeDevCommand": "cd ../.. && ./scripts/stack.sh start",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "./static"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:4174 http://localhost:4174"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}
